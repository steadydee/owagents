{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace-owlswatch-main",
      "skills": [],
      "models": {
        "openai/gpt-5.5": {
          "agentRuntime": {
            "id": "codex"
          }
        }
      },
      "model": {
        "primary": "openai/gpt-5.5"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Owl's Watch Ops",
        "default": true,
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-owlswatch-main",
        "skills": [],
        "tools": {
          "profile": "minimal",
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      },
      {
        "id": "cuenta",
        "name": "Cuenta",
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-owlswatch",
        "agentDir": "~/.openclaw-owlswatch/agents/cuenta/agent",
        "skills": ["intake-receipt"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "owlswatch_operations_upload_attachment",
            "owlswatch_operations_create_expense_draft",
            "owlswatch_telegram_get_file",
            "owlswatch_telegram_download_file",
            "owlswatch_telegram_send_message",
            "owlswatch_telegram_send_chat_action",
            "owlswatch_vision_extract_receipt",
            "owlswatch_album_buffer_check",
            "owlswatch_album_buffer_store",
            "owlswatch_memory_log"
          ],
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      },
      {
        "id": "brain",
        "name": "Brain Intake",
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-dennis-brain",
        "skills": ["brain-intake"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "brain_health_check",
            "brain_submit_intake",
            "brain_submit_telegram_update",
            "brain_telegram_send_message"
          ],
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      },
      {
        "id": "cotiza",
        "name": "Cotiza",
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-owlswatch-cotiza",
        "skills": ["quote-draft"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "owlswatch_gmail_search_quote_threads",
            "owlswatch_gmail_read_thread",
            "owlswatch_quote_prepare",
            "owlswatch_quote_create_draft",
            "owlswatch_quote_revise_draft",
            "owlswatch_telegram_send_message",
            "owlswatch_cotiza_memory_log"
          ],
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      },
      {
        "id": "correo",
        "name": "Correo",
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-owlswatch-correo",
        "skills": ["email-draft"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "owlswatch_email_search_recent_threads",
            "owlswatch_email_search_unanswered_threads",
            "owlswatch_email_read_thread",
            "owlswatch_email_resolve_gmail_url",
            "owlswatch_luna_get_email_response_context",
            "owlswatch_email_submit_operations_intake",
            "owlswatch_email_submit_scan_run",
            "owlswatch_email_upsert_task",
            "owlswatch_email_list_open_tasks",
            "owlswatch_email_create_gmail_draft",
            "owlswatch_email_send_telegram_message",
            "owlswatch_email_memory_log",
            "owlswatch_quote_prepare"
          ],
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      },
      {
        "id": "cobros",
        "name": "Cobros",
        "model": "openai/gpt-5.5",
        "models": {
          "openai/gpt-5.5": {
            "agentRuntime": {
              "id": "codex"
            }
          }
        },
        "workspace": "~/.openclaw/workspace-owlswatch-cobros",
        "skills": ["cuenta-cobro"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "owlswatch_cobros_search_gmail_threads",
            "owlswatch_cobros_read_gmail_thread",
            "owlswatch_cobros_prepare",
            "owlswatch_cobros_create_packet",
            "owlswatch_cobros_create_gmail_draft",
            "owlswatch_cobros_send_telegram_message",
            "owlswatch_cobros_memory_log"
          ],
          "deny": [
            "exec",
            "browser",
            "gateway",
            "cron",
            "nodes",
            "canvas",
            "group:fs",
            "group:web",
            "bundle-mcp"
          ]
        }
      }
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "brain",
      "comment": "Route Dennis Brain private Telegram group to Brain Intake.",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "group",
          "id": "<dennis_brain_group_id>"
        }
      }
    }
  ],
  "gateway": {
    "mode": "local",
    "port": 19001,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<runtime-generated-token-not-committed>"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "<telegram-bot-token-runtime-only>",
      "dmPolicy": "allowlist",
      "allowFrom": ["<dennis_chat_id>", "<adriana_chat_id>"],
      "groupPolicy": "allowlist",
      "groups": {
        "<owl_watch_ops_group_id>": {
          "requireMention": false,
          "topics": {
            "<quotes_topic_id>": {
              "agentId": "cotiza",
              "requireMention": false,
              "groupPolicy": "open",
              "ingest": true
            },
            "<receipts_topic_id>": {
              "agentId": "cuenta",
              "requireMention": false,
              "groupPolicy": "open",
              "ingest": true
            },
            "<cobros_topic_id>": {
              "agentId": "cobros",
              "requireMention": false,
              "groupPolicy": "open",
              "ingest": true
            },
            "1": {
              "agentId": "main",
              "requireMention": false,
              "groupPolicy": "open",
              "ingest": true
            }
          },
          "groupPolicy": "open",
          "ingest": true
        },
        "<dennis_brain_group_id>": {
          "requireMention": false,
          "groupPolicy": "open",
          "ingest": true
        }
      },
      "groupAllowFrom": ["<dennis_chat_id>", "<adriana_chat_id>"]
    }
  },
  "mcp": {
    "servers": {
      "owlswatch_intake": {
        "command": "python3",
        "args": ["~/.openclaw/workspace-owlswatch/tools/owlswatch_intake/server.py"],
        "env": {
          "OWLSWATCH_WORKSPACE": "~/.openclaw/workspace-owlswatch",
          "OPENCLAW_CONFIG_PATH": "~/.openclaw-owlswatch/openclaw.json",
          "OPERATIONS_API_BASE_URL": "https://operations.owlswatch.com",
          "EXPENSE_INTAKE_API_TOKEN": "<runtime-only>",
          "OWLSWATCH_VISION_MODEL": "gpt-4o-mini",
          "OPENAI_API_KEY": "<runtime-only>"
        }
      },
      "owlswatch_quotes": {
        "command": "python3",
        "args": ["~/.openclaw/workspace-owlswatch-cotiza/tools/owlswatch_quotes/server.py"],
        "env": {
          "OWLSWATCH_COTIZA_WORKSPACE": "~/.openclaw/workspace-owlswatch-cotiza",
          "OPENCLAW_CONFIG_PATH": "~/.openclaw-owlswatch/openclaw.json",
          "OPERATIONS_BASE_URL": "https://operations.owlswatch.com",
          "QUOTE_INTAKE_API_TOKEN": "<runtime-only>",
          "OWLSWATCH_GMAIL_ACCOUNT": "info@owlswatch.com",
          "GOOGLE_DRIVE_QUOTES_FOLDER_ID": "1_9QDJAfZ634pkLAxnPiDi1XaNhENQJiE",
          "GOOGLE_APPLICATION_CREDENTIALS": "~/.openclaw-owlswatch/secrets/google-service-account.json",
          "OWLSWATCH_QUOTES_MOCKS": "0",
          "OWLSWATCH_GMAIL_QUOTE_LABEL": "*"
        }
      },
      "owlswatch_email": {
        "command": "python3",
        "args": ["~/.openclaw/workspace-owlswatch-correo/tools/owlswatch_email/server.py"],
        "env": {
          "OWLSWATCH_EMAIL_WORKSPACE": "~/.openclaw/workspace-owlswatch-correo",
          "OPENCLAW_CONFIG_PATH": "~/.openclaw-owlswatch/openclaw.json",
          "OPERATIONS_BASE_URL": "https://operations.owlswatch.com",
          "EMAIL_AGENT_API_TOKEN_FILE": "~/.openclaw-owlswatch/secrets/email-agent-token.tmp",
          "LUNA_BASE_URL": "https://luna.owlswatch.com",
          "OW_AGENT_TOKEN_SECRET": "<runtime-only>",
          "GOOGLE_APPLICATION_CREDENTIALS": "~/.openclaw-owlswatch/secrets/google-service-account.json",
          "OWLSWATCH_GMAIL_ACCOUNT": "info@owlswatch.com",
          "OWLSWATCH_EMAIL_NOTIFY_CHAT_ID": "<owl_watch_ops_group_id>",
          "OWLSWATCH_EMAIL_NOTIFY_THREAD_ID": "<optional_email_topic_id>",
          "OWLSWATCH_GMAIL_DRAFTS_ENABLED": "0"
        }
      },
      "owlswatch_cobros": {
        "command": "python3",
        "args": ["~/.openclaw/workspace-owlswatch-cobros/tools/owlswatch_cobros/server.py"],
        "env": {
          "OWLSWATCH_COBROS_WORKSPACE": "~/.openclaw/workspace-owlswatch-cobros",
          "OPENCLAW_CONFIG_PATH": "~/.openclaw-owlswatch/openclaw.json",
          "OPERATIONS_BASE_URL": "https://operations.owlswatch.com",
          "EMAIL_AGENT_API_TOKEN_FILE": "~/.openclaw-owlswatch/secrets/email-agent-token.tmp",
          "GOOGLE_APPLICATION_CREDENTIALS": "~/.openclaw-owlswatch/secrets/google-service-account.json",
          "OWLSWATCH_GMAIL_ACCOUNT": "info@owlswatch.com",
          "OWLSWATCH_COBROS_FOLDER_ID": "1xBqTQi7_QxTW-WRvmyAOnqafZXizK9wS",
          "OWLSWATCH_COBROS_TEMPLATE_DOC_ID": "1cO6hgB-0ryRRWOvfuxg9jv8x7EIkTAOIDELTkGK0keE",
          "OWLSWATCH_COBROS_PROFILES_PATH": "~/.openclaw/workspace-owlswatch-cobros/data/cobros/operator-billing-profiles.yaml",
          "OWLSWATCH_COBROS_NOTIFY_CHAT_ID": "<owl_watch_ops_group_id>",
          "OWLSWATCH_COBROS_NOTIFY_THREAD_ID": "<optional_cobros_topic_id>"
        }
      },
      "brain_intake": {
        "command": "python3",
        "args": ["~/.openclaw/workspace-dennis-brain/tools/brain_intake/server.py"],
        "env": {
          "OPENCLAW_CONFIG_PATH": "~/.openclaw-owlswatch/openclaw.json",
          "BRAIN_API_BASE_URL": "https://brain-five-kappa.vercel.app",
          "BRAIN_API_TOKEN": "<runtime-only-openclaw-brain-token>"
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      },
      "codex": {
        "enabled": true
      },
      "owlswatch-intake": {
        "enabled": true
      },
      "owlswatch-quotes": {
        "enabled": true
      },
      "owlswatch-email": {
        "enabled": true
      },
      "owlswatch-cobros": {
        "enabled": true
      },
      "brain-intake": {
        "enabled": true
      }
    },
    "load": {
      "paths": [
        "~/.openclaw/workspace-owlswatch/tools/owlswatch_intake",
        "~/.openclaw/workspace-owlswatch-cotiza/tools/owlswatch_quotes",
        "~/.openclaw/workspace-owlswatch-correo/tools/owlswatch_email",
        "~/.openclaw/workspace-owlswatch-cobros/tools/owlswatch_cobros",
        "~/.openclaw/workspace-dennis-brain/tools/brain_intake"
      ]
    }
  },
  "messages": {
    "groupChat": {
      "visibleReplies": "message_tool"
    }
  }
}
