GOOGLE_DRIVE_QUOTES_FOLDER_ID=<quote-folder-id>
GOOGLE_DRIVE_QUOTE_TEMPLATE_SPREADSHEET_ID=<optional-template-id>

OWLSWATCH_QUOTES_MOCKS=0
OWLSWATCH_GMAIL_QUOTE_LABEL=*

# Cobros / cuentas de cobro
OWLSWATCH_COBROS_FOLDER_ID=1v5dWWiLFNbp6v1AjQqsO2Sa3i_uMM0WO
OWLSWATCH_COBROS_TEMPLATE_DOC_ID=1cO6hgB-0ryRRWOvfuxg9jv8x7EIkTAOIDELTkGK0keE
