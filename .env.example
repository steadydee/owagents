# Copy to a machine-local secret environment file if needed.
# Do not commit real values.

OPERATIONS_BASE_URL=https://operations.owlswatch.com
OPERATIONS_API_BASE_URL=https://operations.owlswatch.com

EXPENSE_INTAKE_API_TOKEN=<set-on-runtime-machine-only>
QUOTE_INTAKE_API_TOKEN=<set-on-runtime-machine-only>

OPENAI_API_KEY=<set-on-runtime-machine-only>
OWLSWATCH_VISION_MODEL=gpt-4o-mini

OWLSWATCH_GMAIL_ACCOUNT=info@owlswatch.com
GOOGLE_APPLICATION_CREDENTIALS=<path-to-runtime-service-account-json>
GOOGLE_DRIVE_QUOTES_FOLDER_ID=<quote-folder-id>
GOOGLE_DRIVE_QUOTE_TEMPLATE_SPREADSHEET_ID=<optional-template-id>

OWLSWATCH_QUOTES_MOCKS=0
OWLSWATCH_GMAIL_QUOTE_LABEL=*

